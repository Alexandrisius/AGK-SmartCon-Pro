<Project>
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <LangVersion>12</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- MSB3277: transitive conflicts from RevitAPIUI deps (SSONET, CefSharp) — safe to suppress -->
    <MSBuildWarningsAsMessages>MSB3277</MSBuildWarningsAsMessages>
    <Company>AGK</Company>
    <Product>SmartCon</Product>
    <Copyright>Copyright © AGK 2026</Copyright>
    <RevitApiPath>C:\Program Files\Autodesk\Revit 2025</RevitApiPath>
    <RevitAddinsPath>$(AppData)\Autodesk\Revit\Addins\2025</RevitAddinsPath>
  </PropertyGroup>
</Project>
