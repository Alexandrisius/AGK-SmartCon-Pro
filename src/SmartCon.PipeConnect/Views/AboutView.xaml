<controls:DialogWindowBase x:Class="SmartCon.PipeConnect.Views.AboutView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:conv="clr-namespace:SmartCon.UI.Converters;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource Title_About}"
        Width="520" Height="520" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InvertBoolConverter x:Key="InvBool"/>
        </ui:SingletonResources>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="SmartCon" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding VersionDisplay}"
                        FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                        HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Row 1: Info + buttons -->
        <StackPanel Grid.Row="1">
            <Border Background="{DynamicResource BorderAltBrush}" Height="1" Margin="0,12"/>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource About_Author}" Style="{DynamicResource BodyText}" Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="AGK Engineering" Style="{DynamicResource BodyText}" Margin="8,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource About_Plugin}" Style="{DynamicResource BodyText}" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource About_PluginDesc}" Style="{DynamicResource BodyText}" Margin="8,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource About_Repo}" Style="{DynamicResource BodyText}" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Style="{DynamicResource BodyText}" Margin="8,2">
                    <Hyperlink Command="{Binding OpenLinkCommand}"
                               CommandParameter="https://github.com/Alexandrisius/AGK-SmartCon-Pro">GitHub</Hyperlink>
                </TextBlock>
            </Grid>

            <Border Background="{DynamicResource BorderAltBrush}" Height="1" Margin="0,12"/>

             <TextBlock Text="{DynamicResource Label_Updates}" FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                 <Button Content="{DynamicResource Btn_CheckUpdates}" Width="150"
                        Command="{Binding CheckForUpdateCommand}"
                        IsEnabled="{Binding IsChecking, Converter={StaticResource InvBool}}"
                        Style="{DynamicResource PrimaryButton}"/>
                 <Button Content="{DynamicResource Btn_DownloadInstall}" Width="150" Margin="8,0,0,0"
                        Command="{Binding DownloadAndStageCommand}"
                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                        Style="{DynamicResource AccentButton}"/>
            </StackPanel>

            <ProgressBar Height="5" Margin="0,0,0,6"
                         Value="{Binding DownloadProgress}"
                         Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                         Style="{DynamicResource FlatProgressBar}"/>

            <TextBlock Text="{Binding LatestVersionInfo}" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"
                       Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Row 2: Separator before release notes -->
        <Border Grid.Row="2" Background="{DynamicResource BorderAltBrush}" Height="1"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>

        <!-- Row 3: Release notes - FILLS remaining space -->
        <TextBox Grid.Row="3" Text="{Binding ReleaseNotes}" IsReadOnly="True"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 Padding="10,8" Margin="0,8,0,8" MinHeight="80"
                 FontSize="12" FontFamily="Segoe UI"
                 Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                 BorderBrush="{DynamicResource BorderAltBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>

         <!-- Row 4: Bottom bar -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Style="{DynamicResource BodyText}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox Content="{DynamicResource Chk_CheckOnStartup}" IsChecked="{Binding CheckOnStartup}"
                              Margin="0,0,12,0" Style="{DynamicResource CompactCheckBox}" VerticalAlignment="Center"/>
                     <TextBlock Text="{DynamicResource About_Language}" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                    <ComboBox SelectedIndex="{Binding LanguageIndex}"
                              Width="100" Height="22" FontSize="11" VerticalAlignment="Center">
                        <ComboBoxItem Content="🇷🇺 Русский"/>
                        <ComboBoxItem Content="🇬🇧 English"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="{DynamicResource Btn_Close}" Width="80"
                    Command="{Binding CloseCommand}"
                    Style="{DynamicResource SecondaryButton}"
                    VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</controls:DialogWindowBase>
