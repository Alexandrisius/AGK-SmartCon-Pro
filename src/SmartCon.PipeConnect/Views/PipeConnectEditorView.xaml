<Window x:Class="SmartCon.PipeConnect.Views.PipeConnectEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SmartCon.PipeConnect.Converters"
        Title="Настройка соединения элементов"
        Width="600" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#F5F5F5">

    <Window.Resources>

        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Modern blue button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2979FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" Direction="270" Color="#22000000" BlurRadius="3" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E88E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Foreground" Value="#757575"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button (orange) for "Соединить" -->
        <Style x:Key="ConnectButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#2979FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Modern ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" Direction="270" Color="#15000000" BlurRadius="2" Opacity="0.2"/>
                            </Border.Effect>
                            <Grid>
                                <ToggleButton Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press" Background="Transparent" BorderThickness="0"/>
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="10,3,30,3" VerticalAlignment="Center"/>
                                <Path Data="M0,0 L4,4 L8,0 z" Fill="#555" HorizontalAlignment="Right"
                                      VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="White" CornerRadius="4" Margin="0,2,0,0"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" Direction="270" Color="#22000000" BlurRadius="5" Opacity="0.3"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4,4">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer shadow border -->
    <Border CornerRadius="8" Background="White" Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" Direction="270" Color="#33000000" BlurRadius="10" Opacity="0.4"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>  <!-- Rotation -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>  <!-- Change connector -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>  <!-- Dynamic size -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>  <!-- Fitting -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>  <!-- Move chain checkbox -->
                <RowDefinition Height="*"/>     <!-- Spacer + status -->
                <RowDefinition Height="Auto"/>  <!-- Bottom buttons -->
            </Grid.RowDefinitions>

            <!-- ── Заголовок ──────────────────────────────────────────────────── -->
            <TextBlock Grid.Row="0"
                       Text="Настройка соединения элементов"
                       FontWeight="Bold" FontSize="16"
                       HorizontalAlignment="Center"
                       Foreground="#333333">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" Color="#22000000" BlurRadius="2" Opacity="0.15"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- ── Поворот ────────────────────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ↺ -->
                <Button Grid.Column="0"
                        Content="↺" FontSize="20"
                        Height="40"
                        Padding="0"
                        Command="{Binding RotateLeftCommand}"
                        Style="{StaticResource ModernButton}"
                        ToolTip="Повернуть против часовой стрелки"/>

                <!-- Ввод угла (целое число °) -->
                <Border Grid.Column="2"
                        Background="White" CornerRadius="4" Height="40">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" Direction="270" Color="#15000000" BlurRadius="2" Opacity="0.2"/>
                    </Border.Effect>
                    <TextBox Text="{Binding RotationAngleDeg, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             FontSize="16" Foreground="#333"
                             Background="Transparent" BorderThickness="0"
                             IsEnabled="{Binding IsSessionActive}"
                             Width="90" ToolTip="Угол поворота в градусах"/>
                </Border>

                <!-- ↻ -->
                <Button Grid.Column="4"
                        Content="↻" FontSize="20"
                        Height="40"
                        Padding="0"
                        Command="{Binding RotateRightCommand}"
                        Style="{StaticResource ModernButton}"
                        ToolTip="Повернуть по часовой стрелке"/>
            </Grid>

            <!-- ── Изменить соединение ───────────────────────────────────────── -->
            <Button Grid.Row="4"
                    Height="40"
                    Padding="10,0"
                    HorizontalAlignment="Center"
                    Width="200"
                    Command="{Binding CycleConnectorCommand}"
                    Style="{StaticResource ModernButton}">
                <TextBlock TextAlignment="Center" LineHeight="16">
                    Изменить<LineBreak/>соединение
                </TextBlock>
            </Button>

            <!-- ── Размер dynamic ─────────────────────────────────────────────── -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Размер:"
                           VerticalAlignment="Center"
                           FontSize="12" Foreground="#555"
                           Width="60"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableDynamicSizes}"
                          SelectedItem="{Binding SelectedDynamicSize, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsSessionActive}"
                          Style="{StaticResource ModernComboBox}"
                          ToolTip="Доступные размеры динамического семейства"/>

                <Button Grid.Column="4"
                        Content="Изменить"
                        Height="34"
                        Padding="8,0"
                        Command="{Binding ChangeDynamicSizeCommand}"
                        Style="{StaticResource ModernButton}"
                        ToolTip="Изменить размер динамического семейства"/>
            </Grid>

            <!-- ── Фитинг ─────────────────────────────────────────────────────── -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableFittings}"
                          SelectedItem="{Binding SelectedFitting, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsSessionActive}"
                          Style="{StaticResource ModernComboBox}"
                          ToolTip="Выберите фитинг для соединения"/>

                <Button Grid.Column="2"
                        Content="Вставить"
                        Height="34"
                        Padding="8,0"
                        Command="{Binding InsertFittingCommand}"
                        Style="{StaticResource ModernButton}"
                        ToolTip="Вставить выбранный фитинг (примерка)"/>
            </Grid>

            <!-- ── Глубина цепочки ─────────────────────────────────────── -->
            <Grid Grid.Row="10" Margin="0,4,0,0"
                  Visibility="{Binding HasChain, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Сеть:"
                           VerticalAlignment="Center" Foreground="#444" FontSize="12"/>
                <Button Grid.Column="2" Content="−" Width="28" Height="28"
                        Command="{Binding DecrementChainDepthCommand}"
                        Style="{StaticResource ModernButton}" FontSize="14" Padding="0"
                        ToolTip="Отсоединить последний уровень"/>
                <TextBlock Grid.Column="4" Text="{Binding ChainDepth}" Width="24"
                           TextAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                <Button Grid.Column="6" Content="+" Width="28" Height="28"
                        Command="{Binding IncrementChainDepthCommand}"
                        Style="{StaticResource ModernButton}" FontSize="14" Padding="0"
                        ToolTip="Присоединить следующий уровень"/>
                <TextBlock Grid.Column="8" Text="{Binding ChainDepthHint}"
                           Foreground="#888" FontSize="10"
                           VerticalAlignment="Center" TextWrapping="NoWrap"/>
            </Grid>

            <!-- ── Статус ─────────────────────────────────────────────────────── -->
            <Border Grid.Row="11"
                    Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="8,5" Margin="0,8,0,0"
                    VerticalAlignment="Bottom">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11" Foreground="#444"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ── Нижняя панель ──────────────────────────────────────────────── -->
            <Grid Grid.Row="12" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Индикатор сессии -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4CAF50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Fill" Value="#FF9800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSessionActive}" Value="False">
                                        <Setter Property="Fill" Value="#9E9E9E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#666">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Активно"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="Обработка…"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSessionActive}" Value="False">
                                        <Setter Property="Text" Value="Сессия завершена"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Отмена"
                        Width="90" Height="36"
                        Padding="0"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Style="{StaticResource ModernButton}"
                        Background="#757575"/>

                <Button Grid.Column="3"
                        Content="Соединить"
                        Width="110" Height="36"
                        Padding="0"
                        Command="{Binding ConnectCommand}"
                        IsDefault="True"
                        Style="{StaticResource ConnectButton}"
                        FontWeight="Bold">
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#33000000" BlurRadius="4" Opacity="0.4"/>
                    </Button.Effect>
                </Button>
            </Grid>

        </Grid>
    </Border>
</Window>
