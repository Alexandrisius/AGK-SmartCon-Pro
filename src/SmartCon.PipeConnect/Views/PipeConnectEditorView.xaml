<Window x:Class="SmartCon.PipeConnect.Views.PipeConnectEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SmartCon.PipeConnect.Converters"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        Title="{DynamicResource Title_EditorSetup}"
        Width="600" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ui:SingletonResources>
    </Window.Resources>

    <Border Style="{DynamicResource CardBorder}" Margin="6">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                        Text="{DynamicResource Heading_EditorSetup}"
                       Style="{DynamicResource HeadingText}"
                       HorizontalAlignment="Center"/>

            <!-- Поворот -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="↺" FontSize="18"
                        Style="{DynamicResource IconButton}"
                        Width="36" Height="36"
                        Command="{Binding RotateLeftCommand}"
                         ToolTip="{DynamicResource Tip_RotateCCW}"/>

                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceBrush}" CornerRadius="4"
                        BorderBrush="{DynamicResource BorderAltBrush}" BorderThickness="1"
                        Height="32">
                    <TextBox Text="{Binding RotationAngleDeg, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}"
                             Background="Transparent" BorderThickness="0"
                             IsEnabled="{Binding IsSessionActive}"
                             Width="90" ToolTip="{DynamicResource Tip_RotationAngle}"/>
                </Border>

                <Button Grid.Column="4"
                        Content="↻" FontSize="18"
                        Style="{DynamicResource IconButton}"
                        Width="36" Height="36"
                        Command="{Binding RotateRightCommand}"
                         ToolTip="{DynamicResource Tip_RotateCW}"/>
            </Grid>

            <!-- Изменить соединение -->
            <Button Grid.Row="4"
                    Height="28"
                    Padding="10,3"
                    HorizontalAlignment="Center"
                    Width="190"
                    Command="{Binding CycleConnectorCommand}"
                    ToolTip="{DynamicResource Tip_ChangeConnection}"
                    Style="{DynamicResource PrimaryButton}">
                <TextBlock TextAlignment="Center" FontSize="12" Text="{DynamicResource Btn_ChangeConnection}"/>
            </Button>

            <!-- Размер dynamic -->
            <StackPanel Grid.Row="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="95"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Label_Size}"
                               Style="{DynamicResource LabelText}"
                               VerticalAlignment="Center"
                               Width="58"/>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding AvailableDynamicSizes}"
                              SelectedItem="{Binding SelectedDynamicSize, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              IsEnabled="{Binding IsSessionActive}"
                              Style="{DynamicResource CompactComboBox}"
                              ToolTip="{DynamicResource Tip_AvailableSizes}"/>

                    <Button Grid.Column="4"
                            Content="{DynamicResource Btn_Change}"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding ChangeDynamicSizeCommand}"
                            ToolTip="{DynamicResource Tip_ChangeSize}"/>
                </Grid>
                <TextBlock Text="{Binding SizeChangeInfo}"
                           FontSize="10" Foreground="#E65100" Margin="66,2,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasSizeChangeInfo, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>

            <!-- Фитинг -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="95"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x1F527;" Width="28" Height="28"
                        Command="{Binding ReassignFittingCtcCommand}"
                        Style="{DynamicResource IconButton}" FontSize="14" Padding="0"
                         ToolTip="{DynamicResource Tip_FittingCtc}"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableFittings}"
                          SelectedItem="{Binding SelectedFitting, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsSessionActive}"
                          Style="{DynamicResource CompactComboBox}"
                          ToolTip="{DynamicResource Tip_SelectFitting}"/>

                <Button Grid.Column="4"
                        Content="{DynamicResource Btn_Insert}"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding InsertFittingCommand}"
                        ToolTip="{DynamicResource Tip_InsertFitting}"/>
            </Grid>

            <!-- Переходник (reducer) -->
            <Grid Grid.Row="9" Margin="0,2,0,0"
                  Visibility="{Binding IsReducerVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="95"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x1F527;" Width="28" Height="28"
                        Command="{Binding ReassignReducerCtcCommand}"
                        Style="{DynamicResource IconButton}" FontSize="14" Padding="0"
                        ToolTip="{DynamicResource Tip_ReducerCtc}"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableReducers}"
                          SelectedItem="{Binding SelectedReducer, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsSessionActive}"
                          Style="{DynamicResource CompactComboBox}"
                          ToolTip="{DynamicResource Tip_SelectReducer}"/>

                <Button Grid.Column="4"
                        Content="{DynamicResource Btn_Insert}"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding InsertReducerCommand}"
                        ToolTip="{DynamicResource Tip_InsertReducer}"/>
            </Grid>

            <!-- Глубина цепочки -->
            <Grid Grid.Row="11" Margin="0,2,0,0"
                  Visibility="{Binding HasChain, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Label_Network}"
                           VerticalAlignment="Center" Foreground="#444" FontSize="12"/>
                <Button Grid.Column="2" Content="−" Width="28" Height="28"
                        Command="{Binding DecrementChainDepthCommand}"
                        Style="{DynamicResource IconButton}" FontSize="14" Padding="0"
                         ToolTip="{DynamicResource Tip_ChainDecrement}"/>
                <Button Grid.Column="4" Content="+" Width="28" Height="28"
                        Command="{Binding IncrementChainDepthCommand}"
                        Style="{DynamicResource IconButton}" FontSize="14" Padding="0"
                         ToolTip="{DynamicResource Tip_ChainIncrement}"/>
                <Button Grid.Column="6"
                        Content="{DynamicResource Btn_ConnectAll}" Height="28"
                        Padding="10,0"
                        Command="{Binding ConnectAllChainCommand}"
                        Style="{DynamicResource PrimaryButton}"
                        ToolTip="{DynamicResource Tip_ConnectAll}"/>
            </Grid>

            <!-- Статус -->
            <Border Grid.Row="12"
                    Style="{DynamicResource StatusBarBorder}"
                    VerticalAlignment="Bottom" Margin="0,8,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11" Foreground="#444"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Нижняя панель -->
            <Grid Grid.Row="13" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Fill" Value="#FF9800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSessionActive}" Value="False">
                                        <Setter Property="Fill" Value="#9E9E9E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#666">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{DynamicResource Status_Active}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource Status_Processing}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSessionActive}" Value="False">
                                            <Setter Property="Text" Value="{DynamicResource Status_SessionEnded}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="{DynamicResource Btn_Cancel}"
                        Width="85" Height="28"
                        Padding="0"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Style="{DynamicResource SecondaryButton}"/>

                <Button Grid.Column="3"
                        Content="{DynamicResource Btn_Connect}"
                        Width="105" Height="28"
                        Padding="0"
                        Command="{Binding ConnectCommand}"
                        IsDefault="True"
                        FontWeight="SemiBold"
                        ToolTip="{DynamicResource Tip_Connect}"
                        Style="{DynamicResource AccentButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
