<Window x:Class="SmartCon.PipeConnect.Views.PipeConnectEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SmartCon.PipeConnect.Converters"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        Title="Настройка соединения элементов"
        Width="600" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ui:SingletonResources>
    </Window.Resources>

    <Border Style="{DynamicResource CardBorder}" Margin="6">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Настройка соединения элементов"
                       Style="{DynamicResource HeadingText}"
                       HorizontalAlignment="Center"/>

            <!-- Поворот -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="↺" FontSize="18"
                        Style="{DynamicResource IconButton}"
                        Width="36" Height="36"
                        Command="{Binding RotateLeftCommand}"
                        ToolTip="Повернуть против часовой стрелки"/>

                <Border Grid.Column="2"
                        Background="White" CornerRadius="4"
                        BorderBrush="{DynamicResource BorderAltBrush}" BorderThickness="1"
                        Height="32">
                    <TextBox Text="{Binding RotationAngleDeg, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             FontSize="15" Foreground="#333"
                             Background="Transparent" BorderThickness="0"
                             IsEnabled="{Binding IsSessionActive}"
                             Width="90" ToolTip="Угол поворота в градусах"/>
                </Border>

                <Button Grid.Column="4"
                        Content="↻" FontSize="18"
                        Style="{DynamicResource IconButton}"
                        Width="36" Height="36"
                        Command="{Binding RotateRightCommand}"
                        ToolTip="Повернуть по часовой стрелке"/>
            </Grid>

            <!-- Изменить соединение -->
            <Button Grid.Row="4"
                    Height="28"
                    Padding="10,3"
                    HorizontalAlignment="Center"
                    Width="190"
                    Command="{Binding CycleConnectorCommand}"
                    Style="{DynamicResource PrimaryButton}">
                <TextBlock TextAlignment="Center" FontSize="12">
                    Изменить соединение
                </TextBlock>
            </Button>

            <!-- Размер dynamic -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="95"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Размер:"
                           Style="{DynamicResource LabelText}"
                           VerticalAlignment="Center"
                           Width="58"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableDynamicSizes}"
                          SelectedItem="{Binding SelectedDynamicSize, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsSessionActive}"
                          Style="{DynamicResource CompactComboBox}"
                          ToolTip="Доступные размеры динамического семейства"/>

                <Button Grid.Column="4"
                        Content="Изменить"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding ChangeDynamicSizeCommand}"
                        ToolTip="Изменить размер динамического семейства"/>
            </Grid>

            <!-- Фитинг -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="95"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableFittings}"
                          SelectedItem="{Binding SelectedFitting, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsSessionActive}"
                          Style="{DynamicResource CompactComboBox}"
                          ToolTip="Выберите фитинг для соединения"/>

                <Button Grid.Column="2"
                        Content="Вставить"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding InsertFittingCommand}"
                        ToolTip="Вставить выбранный фитинг (примерка)"/>
            </Grid>

            <!-- Глубина цепочки -->
            <Grid Grid.Row="10" Margin="0,2,0,0"
                  Visibility="{Binding HasChain, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Сеть:"
                           VerticalAlignment="Center" Foreground="#444" FontSize="12"/>
                <Button Grid.Column="2" Content="−" Width="28" Height="28"
                        Command="{Binding DecrementChainDepthCommand}"
                        Style="{DynamicResource IconButton}" FontSize="14" Padding="0"
                        ToolTip="Отсоединить последний уровень"/>
                <TextBlock Grid.Column="4" Text="{Binding ChainDepth}" Width="24"
                           TextAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                <Button Grid.Column="6" Content="+" Width="28" Height="28"
                        Command="{Binding IncrementChainDepthCommand}"
                        Style="{DynamicResource IconButton}" FontSize="14" Padding="0"
                        ToolTip="Присоединить следующий уровень"/>
                <TextBlock Grid.Column="8" Text="{Binding ChainDepthHint}"
                           Style="{DynamicResource CaptionText}"
                           VerticalAlignment="Center" TextWrapping="NoWrap"/>
            </Grid>

            <!-- Статус -->
            <Border Grid.Row="11"
                    Style="{DynamicResource StatusBarBorder}"
                    VerticalAlignment="Bottom" Margin="0,8,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11" Foreground="#444"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Нижняя панель -->
            <Grid Grid.Row="12" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Fill" Value="#FF9800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSessionActive}" Value="False">
                                        <Setter Property="Fill" Value="#9E9E9E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#666">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Активно"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="Обработка…"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSessionActive}" Value="False">
                                        <Setter Property="Text" Value="Сессия завершена"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Отмена"
                        Width="85" Height="28"
                        Padding="0"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Style="{DynamicResource SecondaryButton}"/>

                <Button Grid.Column="3"
                        Content="Соединить"
                        Width="105" Height="28"
                        Padding="0"
                        Command="{Binding ConnectCommand}"
                        IsDefault="True"
                        FontWeight="SemiBold"
                        Style="{DynamicResource AccentButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
