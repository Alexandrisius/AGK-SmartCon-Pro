<controls:DialogWindowBase x:Class="SmartCon.PipeConnect.Views.MiniTypeSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource Title_ConnType}"
        Width="340" Height="280"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <controls:DialogWindowBase.Resources>
        <ui:SingletonResources/>
    </controls:DialogWindowBase.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0"
                 ItemsSource="{Binding AvailableTypes}"
                 SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                 Style="{DynamicResource CompactListBox}"
                 ItemContainerStyle="{DynamicResource CompactListBoxItem}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock FontSize="13">
                        <Run Text="{Binding Code, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text=" — " />
                        <Run Text="{Binding Name, Mode=OneWay}" />
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Btn_Cancel}" Width="80" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" IsCancel="True"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Content="{DynamicResource Btn_OK}" Width="80"
                    Command="{Binding SelectCommand}" IsDefault="True"
                    Style="{DynamicResource AccentButton}"/>
        </StackPanel>
    </Grid>
</controls:DialogWindowBase>
