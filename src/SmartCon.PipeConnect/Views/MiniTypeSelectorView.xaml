<Window x:Class="SmartCon.PipeConnect.Views.MiniTypeSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тип соединения"
        Width="300" Height="220"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListView Grid.Row="0"
                  ItemsSource="{Binding AvailableTypes}"
                  SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                  BorderThickness="1"
                  BorderBrush="#CCCCCC">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="{Binding Code, Mode=OneWay}" />
                        <Run Text=" — " />
                        <Run Text="{Binding Name, Mode=OneWay}" />
                    </TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Отмена" Width="80" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" IsCancel="True" />
            <Button Content="OK" Width="80"
                    Command="{Binding SelectCommand}" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
