<Window x:Class="SmartCon.PipeConnect.Views.MappingEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        Title="Настройки SmartCon"
        Width="930" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources/>
    </Window.Resources>

    <TabControl Margin="8" Style="{DynamicResource FlatTabControl}">

        <!-- Вкладка: Типы коннекторов -->
        <TabItem Header="Типы коннекторов" Style="{DynamicResource FlatTabItem}">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding ConnectorTypes}"
                          SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                          Style="{DynamicResource CompactDataGrid}"
                          RowStyle="{DynamicResource CompactDataGridRow}"
                          CellStyle="{DynamicResource CompactDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код" Binding="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Width="80">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="250">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="4,0,0,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Margin" Value="4,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="4,0,0,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Margin" Value="4,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="+ Добавить" Width="90" Margin="0,0,8,0"
                                Command="{Binding AddTypeCommand}"
                                Style="{DynamicResource PrimaryButton}"/>
                        <Button Content="Удалить" Width="80"
                                Command="{Binding DeleteTypeCommand}"
                                Style="{DynamicResource SecondaryButton}"/>
                    </StackPanel>
                    <Button Content="Сохранить" Width="90"
                            HorizontalAlignment="Right"
                            Command="{Binding SaveTypesCommand}"
                            Style="{DynamicResource AccentButton}"/>
                </Grid>
            </Grid>
        </TabItem>

        <!-- Вкладка: Правила маппинга -->
        <TabItem Header="Правила маппинга" Style="{DynamicResource FlatTabItem}">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding MappingRules}"
                          SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                          Style="{DynamicResource CompactDataGrid}"
                          RowStyle="{DynamicResource CompactDataGridRow}"
                          CellStyle="{DynamicResource CompactDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Тип соединения 1" Width="170">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ConnectorTypes,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Code"
                                              SelectedValue="{Binding FromTypeCode, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{DynamicResource CompactComboBox}"
                                              BorderThickness="0" Height="24"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Тип соединения 2" Width="170">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ConnectorTypes,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Code"
                                              SelectedValue="{Binding ToTypeCode, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{DynamicResource CompactComboBox}"
                                              BorderThickness="0" Height="24"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridCheckBoxColumn Header="Прямое" Binding="{Binding IsDirectConnect, UpdateSourceTrigger=PropertyChanged}" Width="65">
                            <DataGridCheckBoxColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.HeaderStyle>
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource CompactCheckBox}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                            <DataGridCheckBoxColumn.EditingElementStyle>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource CompactCheckBox}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.EditingElementStyle>
                        </DataGridCheckBoxColumn>

                        <DataGridTemplateColumn Header="Фитинги" Width="*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding FamiliesSummary}"
                                            Style="{DynamicResource GhostButton}"
                                            HorizontalContentAlignment="Left"
                                            Command="{Binding OpenFamilySelectorCommand}"
                                            ToolTip="Нажмите для выбора семейств фитингов"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Переходы сечения" Width="*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CompactDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding ReducerFamiliesSummary}"
                                            Style="{DynamicResource GhostButton}"
                                            HorizontalContentAlignment="Left"
                                            Command="{Binding OpenReducerFamilySelectorCommand}"
                                            ToolTip="Нажмите для выбора семейств переходников"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="+ Добавить" Width="90" Margin="0,0,8,0"
                                Command="{Binding AddRuleCommand}"
                                Style="{DynamicResource PrimaryButton}"/>
                        <Button Content="Удалить" Width="80"
                                Command="{Binding DeleteRuleCommand}"
                                Style="{DynamicResource SecondaryButton}"/>
                    </StackPanel>
                    <Button Content="Сохранить" Width="90"
                            HorizontalAlignment="Right"
                            Command="{Binding SaveRulesCommand}"
                            Style="{DynamicResource AccentButton}"/>
                </Grid>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
