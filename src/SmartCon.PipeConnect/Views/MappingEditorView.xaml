<Window x:Class="SmartCon.PipeConnect.Views.MappingEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки SmartCon"
        Width="930" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="0">

            <!-- Вкладка: Типы коннекторов -->
            <TabItem Header="Типы коннекторов">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding ConnectorTypes}"
                              SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Код" Binding="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            <DataGridTextColumn Header="Название" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="250" />
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Left" Margin="0,8,0,0">
                        <Button Content="+ Добавить" Width="90" Margin="0,0,8,0"
                                Command="{Binding AddTypeCommand}" />
                        <Button Content="Удалить" Width="80" Margin="0,0,8,0"
                                Command="{Binding DeleteTypeCommand}" />
                        <Button Content="Сохранить" Width="90"
                                Command="{Binding SaveTypesCommand}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Правила маппинга -->
            <TabItem Header="Правила маппинга">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding MappingRules}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Тип соединения 1" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ConnectorTypes,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Code"
                                                  SelectedValue="{Binding FromTypeCode, UpdateSourceTrigger=PropertyChanged}"
                                                  BorderThickness="0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Тип соединения 2" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ConnectorTypes,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Code"
                                                  SelectedValue="{Binding ToTypeCode, UpdateSourceTrigger=PropertyChanged}"
                                                  BorderThickness="0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridCheckBoxColumn Header="Прямое" Binding="{Binding IsDirectConnect, UpdateSourceTrigger=PropertyChanged}" Width="70" />

                            <DataGridTemplateColumn Header="Фитинги" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding FamiliesSummary}"
                                                Padding="4,2"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding OpenFamilySelectorCommand}"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                ToolTip="Нажмите для выбора семейств фитингов">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Переходы сечения" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ReducerFamiliesSummary}"
                                                Padding="4,2"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding OpenReducerFamilySelectorCommand}"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                ToolTip="Нажмите для выбора семейств переходников">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Left" Margin="0,8,0,0">
                        <Button Content="+ Добавить" Width="90" Margin="0,0,8,0"
                                Command="{Binding AddRuleCommand}" />
                        <Button Content="Удалить" Width="80" Margin="0,0,8,0"
                                Command="{Binding DeleteRuleCommand}" />
                        <Button Content="Сохранить" Width="90"
                                Command="{Binding SaveRulesCommand}" />
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Margin="0,6,0,0" FontSize="11" />
    </Grid>
</Window>
