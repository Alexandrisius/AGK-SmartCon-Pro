<Window x:Class="SmartCon.PipeConnect.Views.FamilySelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        Title="{DynamicResource Title_FamilySelector}"
        Width="640" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Левый список: доступные семейства -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource Label_AvailableFamilies}"
                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource Label_FamilyFilter}"
                           FontSize="10" Foreground="Gray"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding AvailableFamilies}"
                         SelectedItem="{Binding SelectedAvailable, Mode=TwoWay}"
                         Style="{DynamicResource CompactListBox}"
                         ItemContainerStyle="{DynamicResource CompactListBoxItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </DockPanel>

            <!-- Центральные кнопки -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="10,0">
                <Button Content="{DynamicResource Btn_AddFamily}"
                        Width="115" Margin="0,0,0,8"
                        Command="{Binding AddCommand}"
                        Style="{DynamicResource PrimaryButton}"/>
                <Button Content="{DynamicResource Btn_RemoveFamily}"
                        Width="115"
                        Command="{Binding RemoveCommand}"
                        Style="{DynamicResource SecondaryButton}"/>
            </StackPanel>

            <!-- Правый список: выбранные семейства -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top"
                           Text="{DynamicResource Label_SelectedFamilies}"
                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,6,0,0">
                     <Button Content="{DynamicResource Btn_Up}" Width="85" Margin="0,0,6,0"
                             Command="{Binding MoveUpCommand}"
                             Style="{DynamicResource SecondaryButton}"/>
                     <Button Content="{DynamicResource Btn_Down}" Width="85"
                            Command="{Binding MoveDownCommand}"
                            Style="{DynamicResource SecondaryButton}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding SelectedFamilies}"
                         SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                         AlternationCount="999"
                         Style="{DynamicResource CompactListBox}"
                         ItemContainerStyle="{DynamicResource CompactListBoxItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="Gray" MinWidth="22" FontSize="11"
                                           Text="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                               Path=(ItemsControl.AlternationIndex),
                                               StringFormat='{}{0}. '}" />
                                <TextBlock Text="{Binding}" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- Нижние кнопки -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource Btn_Cancel}"
                    Width="95" Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Content="{DynamicResource Btn_Confirm}"
                    Width="110"
                    Command="{Binding ConfirmCommand}"
                    Style="{DynamicResource AccentButton}"/>
        </StackPanel>
    </Grid>
</Window>
