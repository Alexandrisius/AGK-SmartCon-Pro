<Window x:Class="SmartCon.PipeConnect.Views.FamilySelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор семейств фитингов"
        Width="450" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Добавление нового семейства -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding AvailableFamilyNames}"
                      SelectedItem="{Binding SelectedFamilyToAdd}"
                      IsEditable="True"
                      Text="{Binding SelectedFamilyToAdd, UpdateSourceTrigger=PropertyChanged}"
                      Height="26" />
            <Button Grid.Column="1" Content="+ Добавить"
                    Command="{Binding AddFamilyCommand}"
                    Width="90" Height="26" Margin="8,0,0,0" />
        </Grid>

        <!-- Список семейств с кнопками управления -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Список -->
            <ListView Grid.Column="0"
                      ItemsSource="{Binding Families}"
                      SelectedItem="{Binding SelectedFamily, Mode=TwoWay}"
                      BorderThickness="1"
                      BorderBrush="#CCCCCC">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Priority}" FontWeight="Bold" />
                            <TextBlock Grid.Column="1" Text="{Binding FamilyName}" />
                            <TextBlock Grid.Column="2" Text="{Binding SymbolName}" FontSize="11" Foreground="Gray" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Кнопки управления -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <Button Content="↑" ToolTip="Переместить вверх"
                        Command="{Binding MoveUpCommand}"
                        Width="32" Height="32" Margin="0,0,0,4" />
                <Button Content="↓" ToolTip="Переместить вниз"
                        Command="{Binding MoveDownCommand}"
                        Width="32" Height="32" Margin="0,0,0,8" />
                <Button Content="×" ToolTip="Удалить"
                        Command="{Binding RemoveFamilyCommand}"
                        Width="32" Height="32" Background="#FF6B6B" Foreground="White" />
            </StackPanel>
        </Grid>

        <!-- Статус -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Margin="0,8,0,0" FontSize="11" Foreground="Gray" />

        <!-- Кнопки OK/Отмена -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="28"
                    Command="{Binding ConfirmCommand}" IsDefault="True" />
            <Button Content="Отмена" Width="80" Height="28" Margin="8,0,0,0"
                    Command="{Binding CancelCommand}" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
