<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.FamilyMetadataEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource FM_Title_MetadataEdit}"
        Width="420" Height="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource FM_Name}" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"
                     Style="{DynamicResource CompactTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource FM_Description}" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="60" Padding="4,2"
                     VerticalScrollBarVisibility="Auto"
                     Style="{DynamicResource CompactTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource FM_Category}" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"
                     Style="{DynamicResource CompactTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource FM_Tags}" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}" Padding="4,2"
                     Style="{DynamicResource CompactTextBox}"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource FM_Status}" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableStatuses}"
                      SelectedItem="{Binding Status}"
                      Style="{DynamicResource CompactComboBox}"/>
        </StackPanel>

        <Grid Grid.Row="6" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{DynamicResource FM_Save}"
                    Command="{Binding SaveCommand}"
                    MinWidth="80"
                    Style="{DynamicResource PrimaryButton}"/>

            <Button Grid.Column="2"
                    Content="{DynamicResource FM_Cancel}"
                    Command="{Binding CancelCommand}"
                    MinWidth="80"
                    Style="{DynamicResource SecondaryButton}"/>
        </Grid>
    </Grid>
</controls:DialogWindowBase>
