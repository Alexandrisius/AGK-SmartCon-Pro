<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.CategoryTreeEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource FM_CTE_Title}"
        Width="460" Height="520" MinWidth="350" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="{DynamicResource FM_CTE_AddRoot}" Command="{Binding AddRootCommand}"
                    MinWidth="60" Margin="0,0,4,0"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Content="{DynamicResource FM_CTE_AddChild}" Command="{Binding AddChildCommand}"
                    MinWidth="60" Margin="0,0,4,0"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Content="{DynamicResource FM_CTE_Rename}" Command="{Binding RenameCommand}"
                    MinWidth="60" Margin="0,0,4,0"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Content="{DynamicResource FM_CTE_Delete}" Command="{Binding DeleteCommand}"
                    MinWidth="60"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>

        <TreeView Grid.Row="1"
                  ItemsSource="{Binding RootNodes}"
                  SelectedItemChanged="TreeView_SelectedItemChanged"
                  Background="Transparent"
                  BorderBrush="{DynamicResource BorderAltBrush}"
                  BorderThickness="1">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4C1;" Margin="0,0,4,0" FontSize="12"/>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FamilyCount, StringFormat='({0})'}"
                                   Margin="6,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{DynamicResource FM_CTE_Import}" Command="{Binding ImportCommand}"
                    MinWidth="55" Margin="0,0,4,0"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Grid.Column="1" Content="{DynamicResource FM_CTE_Export}" Command="{Binding ExportCommand}"
                    MinWidth="55"
                    Style="{DynamicResource SecondaryButton}"/>
            <Button Grid.Column="3" Content="{DynamicResource FM_CTE_Close}" Command="{Binding CloseCommand}"
                    MinWidth="80"
                    Style="{DynamicResource SecondaryButton}"/>
        </Grid>
    </Grid>
</controls:DialogWindowBase>
