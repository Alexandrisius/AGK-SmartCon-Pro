<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.CategoryTreeEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource FM_CTE_CategoriesAndAttrs}"
        Width="850" Height="580" MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernMenuItem" TargetType="MenuItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="12,7,16,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="1">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ui:SingletonResources>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource FM_CTE_CategoryTree}"
                           FontWeight="SemiBold" Margin="0,0,0,6"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="{DynamicResource FM_CTE_NewCategory}" Command="{Binding AddRootCommand}"
                            MinWidth="60" Margin="0,0,4,0"
                            Style="{DynamicResource SecondaryButton}"/>
                    <Button Content="{DynamicResource FM_CTE_Attributes}" Command="{Binding OpenAttributeLibraryCommand}"
                            MinWidth="60"
                            Style="{DynamicResource SecondaryButton}"/>
                </StackPanel>

                <TreeView ItemsSource="{Binding RootNodes}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          Background="Transparent"
                          BorderBrush="{DynamicResource BorderAltBrush}"
                          BorderThickness="1">
                    <TreeView.ContextMenu>
                        <ContextMenu Style="{StaticResource ModernContextMenu}">
                            <MenuItem Header="{DynamicResource FM_CTE_ContextMenu_Rename}" Command="{Binding ContextMenuRenameCommand}" Style="{StaticResource ModernMenuItem}"/>
                            <MenuItem Header="{DynamicResource FM_CTE_ContextMenu_AddChild}" Command="{Binding ContextMenuAddChildCommand}" Style="{StaticResource ModernMenuItem}"/>
                            <MenuItem Header="{DynamicResource FM_CTE_ContextMenu_Delete}" Command="{Binding ContextMenuDeleteCommand}" Style="{StaticResource ModernMenuItem}"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C1;" Margin="0,0,4,0" FontSize="12"/>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding FamilyCount, StringFormat='({0})'}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedCategory}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{DynamicResource FM_CTE_AttributesFor}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding SelectedCategoryPath, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedCategory}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{DynamicResource FM_CTE_SelectCategory}"/>
                    </TextBlock>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,6"
                      Visibility="{Binding HasSelectedCategory, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableGroups}"
                              SelectedItem="{Binding SelectedGroupFilter}"
                              MinWidth="140" Margin="0,0,8,0"
                              Style="{DynamicResource CompactComboBox}"/>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding AttributeFilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource CompactTextBox}"/>
                        <TextBlock x:Name="SearchPlaceholder"
                                   Text="{DynamicResource FM_CTE_SearchAttrs}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="8,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSelectedCategory, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding AttributeItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" Margin="0,0,6,0">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox" BasedOn="{StaticResource CompactCheckBox}">
                                                    <Setter Property="IsChecked" Value="{Binding IsBound, Mode=OneWay}"/>
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                    <Setter Property="Command" Value="{Binding ToggleBindingCommand}"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsInherited}" Value="True"/>
                                                                <Condition Binding="{Binding IsBound}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>

                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                                        <TextBlock Grid.Column="2" Text="{Binding Group}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Text="{DynamicResource FM_CTE_SelectCategoryHint}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedCategory}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{DynamicResource FM_CTE_Import}"
                    Command="{Binding ImportFromJsonCommand}"
                    MinWidth="80"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="12,4" Margin="0,0,4,0"/>

            <Grid Grid.Column="1" Margin="0,0,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="{DynamicResource FM_CTE_Export}"
                        Command="{Binding ExportFullCommand}"
                        MinWidth="60"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="12,4"/>

                <ToggleButton Grid.Column="1"
                              x:Name="ExportSplitToggle"
                              Width="18"
                              Margin="1,0,0,0"
                              Padding="0"
                              Background="{DynamicResource HoverSurfaceBrush}"
                              BorderBrush="{DynamicResource BorderAltBrush}"
                              BorderThickness="1"
                              Cursor="Hand">
                    <Path Data="M 0,0 L 4,4 L 8,0"
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          StrokeThickness="1.2"
                          Margin="2,3,2,1"
                          Stretch="Uniform"/>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=ExportSplitToggle, Mode=OneWay}"
                       StaysOpen="False"
                       PlacementTarget="{Binding ElementName=ExportSplitToggle}"
                       Placement="Bottom"
                       PopupAnimation="Slide">
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderAltBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="2">
                        <StackPanel>
                            <Button Content="{DynamicResource FM_CTE_ExportTree}"
                                    Command="{Binding ExportCategoriesCommand}"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,6"
                                    MinWidth="180"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="{DynamicResource FM_CTE_ExportAttrs}"
                                    Command="{Binding ExportAttributesCommand}"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,6"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="{DynamicResource FM_CTE_ExportFull}"
                                    Command="{Binding ExportFullCommand}"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,6"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <Button Grid.Column="3"
                    Command="{Binding SaveCommand}"
                    MinWidth="80"
                    Padding="12,4" Margin="0,0,4,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Content" Value="{DynamicResource Btn_Save}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSaved}" Value="True">
                                <Setter Property="Content" Value="{DynamicResource Btn_Saved}"/>
                                <Setter Property="Background" Value="{DynamicResource SavedSuccessBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="4" Content="{DynamicResource Btn_Cancel}"
                    Command="{Binding CancelCommand}"
                    MinWidth="80"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="12,4"/>
        </Grid>
    </Grid>
</controls:DialogWindowBase>
