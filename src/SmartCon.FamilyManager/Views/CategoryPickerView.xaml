<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.CategoryPickerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        xmlns:behaviors="clr-namespace:SmartCon.UI.Behaviors;assembly=SmartCon.UI"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="{DynamicResource FM_CP_Title}"
        Width="380" Height="460" MinWidth="300" MinHeight="250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,2" Margin="0,0,0,8"
                 Style="{DynamicResource CompactTextBox}"/>

        <TreeView x:Name="PickerTree"
                  Grid.Row="1"
                  ItemsSource="{Binding RootNodes}"
                  behaviors:TreeViewBehaviors.DeselectOnEmptyClick="True"
                  Background="Transparent"
                  BorderBrush="{DynamicResource BorderAltBrush}"
                  BorderThickness="1">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SelectedItemChanged">
                    <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}"
                                            CommandParameter="{Binding SelectedItem, ElementName=PickerTree}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource FolderIconGeometry}"
                               Fill="{DynamicResource TextMutedBrush}"
                               Width="13" Height="13"
                               Margin="0,0,6,0"
                               Stretch="Uniform"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource ModernTreeViewItem}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"></Setter>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"></Setter>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <TextBlock Grid.Row="2" Text="{Binding SelectedPath}"
                   Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextTrimming="CharacterEllipsis"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource FM_CP_Clear}" Command="{Binding ClearCommand}" Visibility="Visible"
                    MinWidth="60" Margin="0,0,4,0" Style="{DynamicResource SecondaryButton}"/>
            <Button Content="OK" Command="{Binding SelectCommand}"
                    MinWidth="60" Margin="0,0,4,0" Style="{DynamicResource PrimaryButton}"/>
            <Button Content="{DynamicResource FM_Cancel}" Command="{Binding CancelCommand}"
                    MinWidth="60" Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</controls:DialogWindowBase>
