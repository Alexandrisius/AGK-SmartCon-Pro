<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.ConfirmationDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        xmlns:behaviors="clr-namespace:SmartCon.UI.Behaviors;assembly=SmartCon.UI"
        behaviors:LocalizationBehavior.AutoRefresh="True"
        Title="{Binding Title}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources/>
    </Window.Resources>

    <Grid Margin="16" MinWidth="320">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Message}"
                   Margin="0,0,0,16"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap" MaxWidth="400"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Yes}"
                    Command="{Binding YesCommand}"
                    MinWidth="70"
                    Margin="0,0,8,0"
                    Style="{DynamicResource PrimaryButton}"/>
            <Button Content="{DynamicResource Btn_No}"
                    Command="{Binding NoCommand}"
                    MinWidth="70"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</controls:DialogWindowBase>
