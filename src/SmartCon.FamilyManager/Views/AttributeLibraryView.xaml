<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.AttributeLibraryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        xmlns:behaviors="clr-namespace:SmartCon.UI.Behaviors;assembly=SmartCon.UI"
        behaviors:LocalizationBehavior.AutoRefresh="True"
        Title="{DynamicResource FM_AL_Title}"
        Width="700" Height="480" MinWidth="550" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <Style x:Key="CenterCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ui:SingletonResources>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="AttributesGrid" Grid.Row="0"
                  ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  Style="{DynamicResource CompactDataGrid}"
                  RowStyle="{DynamicResource CompactDataGridRow}"
                  CellStyle="{DynamicResource CompactDataGridCell}"
                  >
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColName"
                                    Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" Width="*"
                                    ElementStyle="{StaticResource CenterCell}"/>
                <DataGridTextColumn x:Name="ColGroup"
                                    Binding="{Binding Group, UpdateSourceTrigger=LostFocus}" Width="120"
                                    ElementStyle="{StaticResource CenterCell}"/>
                <DataGridTemplateColumn x:Name="ColActive" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsActive, Mode=OneWay}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      behaviors:CheckBoxToggleBehavior.ToggleCommand="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      behaviors:CheckBoxToggleBehavior.ToggleCommandParameter="{Binding}"
                                      IsThreeState="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
            <Button Content="{DynamicResource FM_AL_Add}" Command="{Binding AddAttributeCommand}"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,4,0"/>
            <Button Content="{DynamicResource FM_AL_Delete}" Command="{Binding DeleteCommand}"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource Btn_Save}" Command="{Binding SaveCommand}"
                    Style="{DynamicResource PrimaryButton}" MinWidth="80" Margin="0,0,4,0"/>
            <Button Content="{DynamicResource FM_AL_Close}" Command="{Binding CancelCommand}"
                    Style="{DynamicResource SecondaryButton}" MinWidth="80"/>
        </StackPanel>
    </Grid>
</controls:DialogWindowBase>
