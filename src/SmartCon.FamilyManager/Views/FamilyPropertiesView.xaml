<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.FamilyPropertiesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource FM_Props_Title}"
        Width="950" Height="700" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="250" Height="180"
                    CornerRadius="8" BorderThickness="1"
                    BorderBrush="{DynamicResource BorderAltBrush}"
                    Background="{DynamicResource SurfaceBrush}">
                <Grid>
                    <TextBlock Text="{DynamicResource FM_Props_NoAvatar}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <TextBlock.Visibility>
                            <Binding Path="HasAvatar" Converter="{StaticResource BoolToVisibility}" ConverterParameter="Invert"/>
                        </TextBlock.Visibility>
                    </TextBlock>
                    <Image Source="{Binding AvatarImagePath}"
                           Stretch="Uniform" StretchDirection="Both"
                           Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}"/>
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{DynamicResource FM_Props_ChangeImage}"
                                Command="{Binding ChangeAvatarCommand}"
                                Style="{DynamicResource GhostButton}"
                                FontSize="11" Padding="8,2"/>
                        <Button Content="{DynamicResource FM_Props_RemoveImage}"
                                Command="{Binding RemoveAvatarCommand}"
                                Style="{DynamicResource GhostButton}"
                                FontSize="11" Padding="8,2" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource FM_Name}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" FontWeight="SemiBold" Padding="4,2" Margin="0,0,0,12"
                         Height="Auto" MaxHeight="52" TextWrapping="Wrap" AcceptsReturn="False"
                         Style="{DynamicResource CompactTextBox}"/>

                <TextBlock Text="{DynamicResource FM_Category}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding CategoryPath, Mode=OneWay}" IsReadOnly="True"
                             Padding="4,2" Style="{DynamicResource CompactTextBox}"
                             Background="{DynamicResource HoverAltSurfaceBrush}"/>
                    <Button Grid.Column="1" Content="..." Command="{Binding PickCategoryCommand}"
                            Width="28" Height="24" Margin="4,0,0,0"
                            Style="{DynamicResource SecondaryButton}" Padding="0"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource FM_Status}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableStatuses}"
                              SelectedItem="{Binding ContentStatus}"
                              Style="{DynamicResource CompactComboBox}"/>
                </Grid>

                <TextBlock Text="{DynamicResource FM_Props_Manufacturer}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                <TextBox Text="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,2" Margin="0,0,0,8"
                         Style="{DynamicResource CompactTextBox}"/>

                <TextBlock Text="{DynamicResource FM_Tags}" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,2" Margin="0,0,0,8"
                         Style="{DynamicResource CompactTextBox}"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11">
                        <Run Text="{DynamicResource FM_Props_Version}"/>: <Run Text="{Binding VersionLabel, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="16,0,0,0">
                        <Run Text="{DynamicResource FM_Props_Size}"/>: <Run Text="{Binding FileSizeText, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Separator Grid.Row="1" Margin="0,0,0,8" Background="{DynamicResource BorderAltBrush}"/>

        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}"
                    Style="{DynamicResource FlatTabControl}">

            <TabItem Style="{DynamicResource FlatTabItem}">
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource FM_Tab_General}"/>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource FM_Description}" FontWeight="SemiBold" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="100" Padding="6,4"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{DynamicResource CompactTextBox}" Margin="0,0,0,16"/>

                        <TextBlock Text="{DynamicResource FM_Props_FileInfo}" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource FM_Props_Created}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CreatedAtText, Mode=OneWay}" Margin="8,2" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource FM_Props_Updated}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UpdatedAtText, Mode=OneWay}" Margin="8,2" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{DynamicResource FlatTabItem}">
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource FM_Tab_Content}"/>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>

                        <Expander Header="{DynamicResource FM_Props_Images}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}"
                                        CommandParameter="Image"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ImageAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_SetPrimary}"
                                                        Command="{Binding DataContext.SetAsPrimaryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="3" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>

                        <Expander Header="{DynamicResource FM_Props_Videos}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}" CommandParameter="Video"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding VideoAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                        <Expander Header="{DynamicResource FM_Props_Documents}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}" CommandParameter="Document"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding DocumentAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                        <Expander Header="{DynamicResource FM_Props_LookupTables}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}" CommandParameter="LookupTable"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding LookupAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                        <Expander Header="{DynamicResource FM_Props_Spreadsheets}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="{DynamicResource FM_Props_XlsNote}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,0,0,8"/>
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}" CommandParameter="Spreadsheet"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding SpreadsheetAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                        <Expander Header="{DynamicResource FM_Props_Models3D}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}" CommandParameter="Model3D"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Model3DAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                        <Expander Header="{DynamicResource FM_Props_Other}" IsExpanded="True" Margin="0,0,0,8">
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="{DynamicResource FM_Props_Add}"
                                        Command="{Binding AddAssetCommand}" CommandParameter="Other"
                                        Style="{DynamicResource SecondaryButton}"
                                        FontSize="11" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding OtherAssets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="{DynamicResource FM_Props_Open}"
                                                        Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                                <Button Grid.Column="2" Content="{DynamicResource FM_Props_Delete}"
                                                        Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1" Margin="4,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{DynamicResource FlatTabItem}">
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource FM_Tab_Attributes}"/>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{Binding PresetCategoryInfo, Mode=OneWay}"
                                   FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <ItemsControl ItemsSource="{Binding EffectiveParameters}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1" Text="—"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                         <TextBlock Text="{DynamicResource FM_Props_NoPresets}"
                                    Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                                    HorizontalAlignment="Center" Margin="0,24"
                                    Visibility="{Binding HasPresets, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>

                         <TextBlock Text="{DynamicResource FM_Props_NoAttributes}"
                                    FontWeight="SemiBold" Margin="0,16,0,4"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource FM_Props_NoAttributesDesc}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{DynamicResource FlatTabItem}">
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource FM_Tab_3DView}"/>
                </TabItem.Header>
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="{DynamicResource FM_Props_3DComingSoon}"
                                   FontWeight="SemiBold" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource FM_Props_3DDesc}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding Model3DAssets}" HorizontalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                        <Button Content="{DynamicResource FM_Props_Open}"
                                                Command="{Binding DataContext.OpenAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource GhostButton}" FontSize="10" Padding="4,1"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <Grid Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="{DynamicResource FM_Save}"
                    Command="{Binding SaveCommand}"
                    MinWidth="100"
                    Style="{DynamicResource PrimaryButton}"/>
            <Button Grid.Column="2"
                    Content="{DynamicResource FM_Cancel}"
                    Command="{Binding CancelCommand}"
                    MinWidth="100"
                    Style="{DynamicResource SecondaryButton}"/>
        </Grid>
    </Grid>
</controls:DialogWindowBase>
