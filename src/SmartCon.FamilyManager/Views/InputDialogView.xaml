<UserControl x:Class="SmartCon.FamilyManager.Views.InputDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
             MinWidth="300" MinHeight="120"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <ui:SingletonResources/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Prompt}"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource TextBrush}"
                   TextWrapping="Wrap"/>

        <TextBox Grid.Row="1"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,16"
                 Padding="6,4"
                 Style="{DynamicResource CompactTextBox}"
                 x:Name="InputTextBox"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    MinWidth="70"
                    Margin="0,0,8,0"
                    Style="{DynamicResource PrimaryButton}"/>
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    MinWidth="70"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
