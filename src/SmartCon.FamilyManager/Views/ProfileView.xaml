<controls:DialogWindowBase x:Class="SmartCon.FamilyManager.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        xmlns:loc="clr-namespace:SmartCon.UI.Localization;assembly=SmartCon.UI"
        xmlns:converters="clr-namespace:SmartCon.UI.Converters;assembly=SmartCon.UI"
        xmlns:models="clr-namespace:SmartCon.Core.Models.FamilyManager;assembly=SmartCon.Core"
        xmlns:behaviors="clr-namespace:SmartCon.UI.Behaviors;assembly=SmartCon.UI"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="{loc:Loc FM_ProfileTitle}"
        Width="460" Height="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <controls:DialogWindowBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:SingletonResources/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <ObjectDataProvider x:Key="Roles" MethodName="GetValues" ObjectType="{x:Type models:DbUserRole}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="models:DbUserRole"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </controls:DialogWindowBase.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="6" BorderBrush="{DynamicResource BorderAltBrush}"
                BorderThickness="1" Margin="0,0,0,12">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                        Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="{Binding Initials}"
                               Foreground="White" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUser.DisplayName}"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding CurrentUser.Role}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding CurrentUserIdentity.UserId}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,8"
              Visibility="{Binding IsOwner, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{loc:Loc FM_ProfileUsers}"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding UserCount, StringFormat='{}{0} пользователей'}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsOwner, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Users}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" BorderBrush="{DynamicResource BorderAltBrush}"
                                    BorderThickness="1" Margin="0,0,0,4" Padding="10,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}">
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBanned}" Value="True">
                                                <Setter Property="Opacity" Value="0.55">
                                                </Setter>
                                                <Setter Property="Background" Value="#FFF5F5F5">
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" FontSize="12"/>
                                            <TextBlock Text=" ★" FontSize="10" Foreground="#FFB300">
                                                <TextBlock.Visibility>
                                                    <Binding Path="IsOwnerRow" Converter="{StaticResource BoolToVis}"/>
                                                </TextBlock.Visibility>
                                            </TextBlock>
                                            <TextBlock Text="{loc:Loc FM_StatusBanned}" FontSize="10" Foreground="#E53935" FontWeight="SemiBold" Margin="6,0,0,0">
                                                <TextBlock.Visibility>
                                                    <Binding Path="IsBanned" Converter="{StaticResource BoolToVis}"/>
                                                </TextBlock.Visibility>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding MachineId}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              SelectedItem="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                              ItemsSource="{Binding Source={StaticResource Roles}}"
                                              IsEnabled="{Binding CanEditRole}"
                                              Width="100" Margin="4,0"
                                              Style="{DynamicResource CompactComboBox}"
                                              behaviors:ComboBoxConfirmBehavior.IsConfirmationEnabled="True"
                                              behaviors:ComboBoxConfirmBehavior.Command="{Binding ChangeRoleCommand}"
                                              behaviors:ComboBoxConfirmBehavior.ConfirmTitle="{loc:Loc FM_RoleChangeConfirmTitle}"
                                              behaviors:ComboBoxConfirmBehavior.ConfirmMessage="{loc:Loc FM_RoleChangeConfirmMessage}"/>

                                    <Button Grid.Column="2"
                                            Command="{Binding ToggleBanCommand}"
                                            Width="24" Height="24"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="0" Margin="2,0"
                                            ToolTip="Ban/Unban">
                                        <Button.Visibility>
                                            <Binding Path="CanToggleBan" Converter="{StaticResource BoolToVis}">
                                            </Binding>
                                        </Button.Visibility>
                                        <TextBlock Text="&#x1F512;"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,32,0,0">
                <StackPanel.Visibility>
                    <Binding Path="IsOwner" Converter="{StaticResource BoolToVis}" ConverterParameter="Invert"/>
                </StackPanel.Visibility>
                <TextBlock Text="{Binding CurrentRoleLabel}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentRoleDescription}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <Button Grid.Row="3"
                Command="{Binding CloseCommand}"
                Content="{loc:Loc Btn_Close}"
                IsCancel="True"
                Style="{DynamicResource SecondaryButton}"
                Width="80" Height="28" HorizontalAlignment="Right"
                Margin="0,12,0,0"/>
    </Grid>
</controls:DialogWindowBase>
