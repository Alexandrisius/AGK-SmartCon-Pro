<UserControl x:Class="SmartCon.FamilyManager.Views.FamilyManagerPaneControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        xmlns:vm="clr-namespace:SmartCon.FamilyManager.ViewModels"
        xmlns:behaviors="clr-namespace:SmartCon.UI.Behaviors;assembly=SmartCon.UI"
        xmlns:loc="clr-namespace:SmartCon.UI.Localization;assembly=SmartCon.UI"
        xmlns:converters="clr-namespace:SmartCon.UI.Converters;assembly=SmartCon.UI"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
         Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:SingletonResources/>
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="DangerIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderAltBrush}"/>
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFFEECEE"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FFE53935"/>
                                    <Setter Property="Foreground" Value="#FFE53935"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFFDDDDD"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DisabledBgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernMenuItem" TargetType="MenuItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="12,7,16,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="1">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerMenuItem" TargetType="MenuItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="12,7,16,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="1">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FFFEECEE"/>
                                    <Setter Property="Foreground" Value="#FFE53935"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FFFDDDDD"/>
                                    <Setter Property="Foreground" Value="#FFC62828"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" Margin="0,0,4,4">
                <Button Command="{Binding RefreshTreeCommand}"
                        Margin="0,0,4,0"
                        Width="28" Height="28"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="0"
                        ToolTip="{loc:Loc FM_RefreshTooltip}">
                    <TextBlock Text="&#x21BB;"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-1,0,0"/>
                </Button>

                <ComboBox ItemsSource="{Binding Connections}"
                          SelectedItem="{Binding SelectedConnection}"
                          DisplayMemberPath="Name"
                          VerticalContentAlignment="Center"
                          Margin="0,0,4,0"
                          MinWidth="120"
                          Style="{DynamicResource CompactComboBox}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,4,4">
                <Button Command="{Binding CreateDatabaseCommand}"
                        Margin="0,0,2,0"
                        Width="28" Height="28"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="0"
                        ToolTip="{loc:Loc FM_Tip_CreateDb}">
                    <Viewbox Width="8" Height="8" Stretch="Uniform">
                        <Path Data="M 0,4 L 8,4 M 4,0 L 4,8"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="1.5"/>
                    </Viewbox>
                </Button>

                <Button Command="{Binding ConnectDatabaseCommand}"
                        Margin="0,0,2,0"
                        Width="28" Height="28"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="0"
                        ToolTip="{loc:Loc FM_Tip_ConnectDb}">
                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                        <Path Data="M 1,5 L 4,8 L 9,2"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Viewbox>
                </Button>

                <Button Command="{Binding DisconnectDatabaseCommand}"
                        Margin="0,0,2,0"
                        Width="28" Height="28"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="0"
                        ToolTip="{loc:Loc FM_Disconnect}">
                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                        <Path Data="M 1,1 L 9,9 M 9,1 L 1,9"
                              Stroke="{DynamicResource TextMutedBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Viewbox>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Grid Visibility="{Binding CanImport, Converter={StaticResource BoolToVis}}" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{loc:Loc FM_ImportFile}"
                            Command="{Binding ImportFilesCommand}"
                            MinWidth="80"
                            Style="{DynamicResource SecondaryButton}"
                            Margin="0,0,0,0"
                            Padding="8,4"/>

                    <ToggleButton Grid.Column="1"
                                  x:Name="ImportSplitToggle"
                                  Width="18"
                                  Margin="1,0,0,0"
                                  Style="{DynamicResource ModernSplitToggle}">
                        <Path Data="M 0,0 L 4,4 L 8,0"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="1.2"
                              Margin="2,3,2,1"
                              Stretch="Uniform"/>
                    </ToggleButton>

                    <Popup IsOpen="{Binding IsChecked, ElementName=ImportSplitToggle, Mode=OneWay}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=ImportSplitToggle}"
                           Placement="Bottom"
                           AllowsTransparency="True">
                        <Border Background="White"
                                BorderBrush="{DynamicResource BorderAltBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="4">
                            <StackPanel>
                                <Button Content="{loc:Loc FM_ImportFile}"
                                        Command="{Binding ImportFilesCommand}"
                                        MinWidth="140"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                                <Button Content="{loc:Loc FM_ImportFolder}"
                                        Command="{Binding ImportFolderCommand}"
                                        MinWidth="140"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Button Command="{Binding OpenProfileCommand}"
                        Width="28" Height="28"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="0"
                        ToolTip="{loc:Loc FM_Profile}">
                    <Viewbox Width="12" Height="12" Stretch="Uniform">
                        <Path Data="M 6,0 C 7.66,0 9,1.34 9,3 C 9,4.66 7.66,6 6,6 C 4.34,6 3,4.66 3,3 C 3,1.34 4.34,0 6,0 Z M 6,7.5 C 9.31,7.5 12,8.84 12,10.5 L 12,12 L 0,12 L 0,10.5 C 0,8.84 2.69,7.5 6,7.5 Z"
                              Fill="{DynamicResource TextPrimaryBrush}"/>
                    </Viewbox>
                </Button>
            </StackPanel>
        </WrapPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     Padding="6,4,24,4"
                     Style="{DynamicResource CompactTextBox}"
                     behaviors:TextBoxBehaviors.Placeholder="{Binding ElementName=SearchPlaceholder}"
                     Background="Transparent"/>
            <TextBlock x:Name="SearchPlaceholder"
                       Text="{loc:Loc FM_SearchPlaceholder}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="8,0,24,0"
                       IsHitTestVisible="False"/>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding ClearSearchCommand}"
                    Width="20" Height="20"
                    Margin="0,0,4,0"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="0"
                    Visibility="{Binding IsSearchNotEmpty, Converter={StaticResource BoolToVis}}">
                <Viewbox Width="10" Height="10" Stretch="Uniform">
                    <Path Data="M 0,0 L 8,8 M 8,0 L 0,8"
                          Stroke="{DynamicResource TextMutedBrush}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                </Viewbox>
            </Button>
        </Grid>

        <TreeView Grid.Row="2"
                  x:Name="CategoryTree"
                  ItemsSource="{Binding TreeNodes}"
                  behaviors:TreeViewBehaviors.RightClickSelect="True"
                  behaviors:TreeViewBehaviors.DeselectOnEmptyClick="True"
                  behaviors:TreeViewDragDropBehavior.StartDragCommand="{Binding StartDragCommand}"
                  behaviors:TreeViewDragDropBehavior.DropCommand="{Binding DropFamilyCommand}"
                  behaviors:TreeViewDragDropBehavior.AutoExpandDelayMilliseconds="500"
                  Background="Transparent"
                  BorderBrush="{DynamicResource BorderAltBrush}"
                  BorderThickness="1"
                  Padding="2"
                  AllowDrop="True">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SelectedItemChanged">
                    <i:InvokeCommandAction Command="{Binding TreeViewSelectedItemChangedCommand}"
                                           CommandParameter="{Binding SelectedItem, ElementName=CategoryTree}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vm:CategoryNodeViewModel}"
                                           ItemsSource="{Binding Children}">
                    <Grid Background="Transparent" HorizontalAlignment="Stretch"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FolderIconGeometry}"
                                   Fill="{DynamicResource TextMutedBrush}"
                                   Width="14" Height="14"
                                   Margin="0,0,6,0"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FamilyCount, StringFormat=' ({0})'}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                        <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}"
                                         DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{loc:Loc FM_ImportFileToCategory}"
                                          Command="{Binding ImportFileToCategoryCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{loc:Loc FM_ImportFolderToCategory}"
                                          Command="{Binding ImportFolderToCategoryCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <Separator />
                                <MenuItem Header="{loc:Loc FM_ImportDataForCategory}"
                                          Command="{Binding ImportDataForCategoryCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </HierarchicalDataTemplate>

                <HierarchicalDataTemplate DataType="{x:Type vm:FamilyLeafNodeViewModel}"
                                             ItemsSource="{Binding Children}">
                    <Grid Background="Transparent" HorizontalAlignment="Stretch"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding VersionLabel, StringFormat=' {}({0})'}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                        <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}"
                                         Focusable="False"
                                         DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                 <MenuItem Header="{loc:Loc FM_LoadAndPlace}"
                                          Command="{Binding LoadAndPlaceCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{loc:Loc FM_LoadToProject}"
                                          Command="{Binding LoadToProjectCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{loc:Loc FM_ImportData}"
                                          Command="{Binding ImportDataCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{loc:Loc FM_Update}"
                                          Command="{Binding UpdateFamilyCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{loc:Loc FM_Properties}"
                                          Command="{Binding OpenPropertiesCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{loc:Loc FM_DeleteFromCatalog}"
                                          Command="{Binding DeleteFamilyCommand}"
                                          Style="{StaticResource DangerMenuItem}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </HierarchicalDataTemplate>

                <DataTemplate DataType="{x:Type vm:FamilyTypeNodeViewModel}">
                    <Grid Background="Transparent" HorizontalAlignment="Stretch"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <TextBlock Text="{Binding DisplayName}"
                                   VerticalAlignment="Center" />
                        <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}"
                                         Focusable="False"
                                         DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{loc:Loc FM_PlaceType}"
                                          Command="{Binding PlaceTypeCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource ModernTreeViewItem}">
                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"></Setter>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"></Setter>
                    <Setter Property="AllowDrop" Value="False"></Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCategory}" Value="True">
                            <Setter Property="AllowDrop" Value="True"></Setter>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSelected}" Value="False"></Condition>
                                <Condition Binding="{Binding IsType}" Value="True"></Condition>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"></Setter>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding TotalItemCount}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>

            <Button Grid.Column="2"
                    Command="{Binding OpenCategoryEditorCommand}"
                    Width="24" Height="24" Margin="4,0,0,0"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="0"
                    ToolTip="{loc:Loc FM_Tip_EditCategories}">
                <Viewbox Width="14" Height="14" Stretch="Uniform">
                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                          Fill="{DynamicResource TextMutedBrush}"/>
                </Viewbox>
            </Button>
        </Grid>
    </Grid>
</UserControl>
