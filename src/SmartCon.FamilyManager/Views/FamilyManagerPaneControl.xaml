<UserControl x:Class="SmartCon.FamilyManager.Views.FamilyManagerPaneControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <ui:SingletonResources/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Databases}"
                      SelectedItem="{Binding SelectedDatabase}"
                      DisplayMemberPath="Name"
                      VerticalContentAlignment="Center"
                      Margin="0,0,4,0"
                      Style="{DynamicResource CompactComboBox}"/>

            <Button Grid.Column="1"
                    Content="+"
                    Command="{Binding CreateDatabaseCommand}"
                    Margin="0,0,4,0"
                    MinWidth="24"
                    Style="{DynamicResource SecondaryButton}"/>

            <Button Grid.Column="2"
                    Content="🗑"
                    Command="{Binding DeleteDatabaseCommand}"
                    Margin="0,0,8,0"
                    MinWidth="24"
                    Style="{DynamicResource SecondaryButton}"/>

            <TextBox Grid.Column="3"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     Padding="6,4"
                     Margin="0,0,4,0"
                     Style="{DynamicResource CompactTextBox}"/>

            <Button Grid.Column="4"
                    Content="{DynamicResource FM_Search}"
                    Command="{Binding SearchCommand}"
                    Margin="0,0,4,0"
                    MinWidth="60"
                    Style="{DynamicResource SecondaryButton}"/>

            <Button Grid.Column="5"
                    Content="{DynamicResource FM_ImportFile}"
                    Command="{Binding ImportFileCommand}"
                    Margin="0,0,4,0"
                    MinWidth="80"
                    Style="{DynamicResource SecondaryButton}"/>

            <Button Grid.Column="6"
                    Content="{DynamicResource FM_ImportFolder}"
                    Command="{Binding ImportFolderCommand}"
                    Margin="0,0,4,0"
                    MinWidth="80"
                    Style="{DynamicResource SecondaryButton}"/>

            <Button Grid.Column="7"
                    Content="{DynamicResource FM_LoadToProject}"
                    Command="{Binding LoadToProjectCommand}"
                    IsEnabled="{Binding CanLoadToProject}"
                    MinWidth="100"
                    Style="{DynamicResource PrimaryButton}"/>
        </Grid>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding FamilyItemsView}"
                  SelectedItem="{Binding SelectedItem}"
                  Style="{DynamicResource CompactDataGrid}"
                  RowStyle="{DynamicResource CompactDataGridRow}"
                  CellStyle="{DynamicResource CompactDataGridCell}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderAltBrush}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Удалить из каталога"
                             Command="{Binding DeleteFamilyCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander IsExpanded="True"
                                                  Header="{Binding Name}"
                                                  Background="{DynamicResource HoverAltSurfaceBrush}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  BorderBrush="{DynamicResource BorderAltBrush}"
                                                  BorderThickness="0,0,0,1"
                                                  Padding="4,2">
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColName" Binding="{Binding Name}" Width="*" MinWidth="120"/>
                <DataGridTextColumn x:Name="ColStatus" Binding="{Binding Status}" Width="80" MinWidth="60"/>
                <DataGridTextColumn x:Name="ColVersion" Binding="{Binding VersionLabel}" Width="60" MinWidth="50"/>
                <DataGridTextColumn x:Name="ColUpdated" Binding="{Binding UpdatedAtUtc, StringFormat='{}{0:yyyy-MM-dd}'}" Width="90" MinWidth="70"/>
            </DataGrid.Columns>
        </DataGrid>

            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding TotalItemCount}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>

                <Button Grid.Column="2"
                        Content="{DynamicResource FM_EditMetadata}"
                        Command="{Binding EditMetadataCommand}"
                        IsEnabled="{Binding CanLoadToProject}"
                        Margin="8,0,0,0"
                        MinWidth="80"
                        Style="{DynamicResource SecondaryButton}"/>
            </Grid>
    </Grid>
</UserControl>
