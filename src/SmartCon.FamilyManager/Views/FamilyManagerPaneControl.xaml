<UserControl x:Class="SmartCon.FamilyManager.Views.FamilyManagerPaneControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        xmlns:vm="clr-namespace:SmartCon.FamilyManager.ViewModels"
        xmlns:behaviors="clr-namespace:SmartCon.UI.Behaviors;assembly=SmartCon.UI"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
         behaviors:LocalizationBehavior.AutoRefresh="True"
         Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:SingletonResources/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="DangerIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderAltBrush}"/>
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFFEECEE"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FFE53935"/>
                                    <Setter Property="Foreground" Value="#FFE53935"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFFDDDDD"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DisabledBgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernMenuItem" TargetType="MenuItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="12,7,16,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="1">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverSurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PressedSurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerMenuItem" TargetType="MenuItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="12,7,16,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="1">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FFFEECEE"/>
                                    <Setter Property="Foreground" Value="#FFE53935"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FFFDDDDD"/>
                                    <Setter Property="Foreground" Value="#FFC62828"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Connections}"
                      SelectedItem="{Binding SelectedConnection}"
                      DisplayMemberPath="Name"
                      VerticalContentAlignment="Center"
                      Margin="0,0,4,0"
                      Style="{DynamicResource CompactComboBox}"/>

            <Button Grid.Column="1"
                    Command="{Binding CreateDatabaseCommand}"
                    Margin="0,0,2,0"
                    Width="28" Height="26"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="0"
                    ToolTip="{DynamicResource FM_Tip_CreateDb}">
                <Viewbox Width="8" Height="8" Stretch="Uniform">
                    <Path Data="M 0,4 L 8,4 M 4,0 L 4,8"
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          StrokeThickness="1.5"/>
                </Viewbox>
            </Button>

            <Button Grid.Column="2"
                    Command="{Binding ConnectDatabaseCommand}"
                    Margin="0,0,2,0"
                    Width="28" Height="26"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="0"
                    ToolTip="{DynamicResource FM_Tip_ConnectDb}">
                <Viewbox Width="10" Height="10" Stretch="Uniform">
                    <Path Data="M 1,5 L 4,8 L 9,2"
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                </Viewbox>
            </Button>

            <Button Grid.Column="3"
                    Command="{Binding DisconnectDatabaseCommand}"
                    Margin="0,0,2,0"
                    Width="28" Height="26"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="0"
                    ToolTip="{DynamicResource FM_Disconnect}">
                <Viewbox Width="10" Height="10" Stretch="Uniform">
                    <Path Data="M 1,1 L 9,9 M 9,1 L 1,9"
                          Stroke="{DynamicResource TextMutedBrush}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                </Viewbox>
            </Button>

            <Grid Grid.Column="4" Margin="0,0,4,0">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="6,4"
                         Style="{DynamicResource CompactTextBox}"
                         behaviors:TextBoxBehaviors.Placeholder="{Binding ElementName=SearchPlaceholder}"
                         Background="Transparent"/>
                <TextBlock x:Name="SearchPlaceholder"
                           Text="{DynamicResource FM_SearchPlaceholder}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="8,0,0,0"
                           IsHitTestVisible="False"/>
            </Grid>

            <Grid Grid.Column="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{DynamicResource FM_ImportFile}"
                        Command="{Binding ImportFilesCommand}"
                        MinWidth="80"
                        Style="{DynamicResource SecondaryButton}"
                        Margin="0,0,0,0"
                        Padding="8,4"/>

                <ToggleButton Grid.Column="1"
                              x:Name="ImportSplitToggle"
                              Width="18"
                              Margin="1,0,0,0"
                              Style="{DynamicResource ModernSplitToggle}">
                    <Path Data="M 0,0 L 4,4 L 8,0"
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          StrokeThickness="1.2"
                          Margin="2,3,2,1"
                          Stretch="Uniform"/>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=ImportSplitToggle, Mode=OneWay}"
                       StaysOpen="False"
                       PlacementTarget="{Binding ElementName=ImportSplitToggle}"
                       Placement="Bottom"
                       AllowsTransparency="True">
                    <Border Background="White"
                            BorderBrush="{DynamicResource BorderAltBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4">
                        <StackPanel>
                            <Button Content="{DynamicResource FM_ImportFile}"
                                    Command="{Binding ImportFilesCommand}"
                                    MinWidth="140"
                                    HorizontalContentAlignment="Left"
                                    Padding="10,6"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button Content="{DynamicResource FM_ImportFolder}"
                                    Command="{Binding ImportFolderCommand}"
                                    MinWidth="140"
                                    HorizontalContentAlignment="Left"
                                    Padding="10,6"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>

        <TreeView Grid.Row="1"
                  x:Name="CategoryTree"
                  ItemsSource="{Binding TreeNodes}"
                  behaviors:TreeViewBehaviors.RightClickSelect="True"
                  behaviors:TreeViewBehaviors.DeselectOnEmptyClick="True"
                  behaviors:TreeViewDragDropBehavior.StartDragCommand="{Binding StartDragCommand}"
                  behaviors:TreeViewDragDropBehavior.DropCommand="{Binding DropFamilyCommand}"
                  behaviors:TreeViewDragDropBehavior.AutoExpandDelayMilliseconds="500"
                  Background="Transparent"
                  BorderBrush="{DynamicResource BorderAltBrush}"
                  BorderThickness="1"
                  Padding="2"
                  AllowDrop="True">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SelectedItemChanged">
                    <i:InvokeCommandAction Command="{Binding TreeViewSelectedItemChangedCommand}"
                                           CommandParameter="{Binding SelectedItem, ElementName=CategoryTree}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vm:CategoryNodeViewModel}"
                                           ItemsSource="{Binding Children}">
                    <Grid Background="Transparent" HorizontalAlignment="Stretch"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FolderIconGeometry}"
                                   Fill="{DynamicResource TextMutedBrush}"
                                   Width="14" Height="14"
                                   Margin="0,0,6,0"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FamilyCount, StringFormat=' ({0})'}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                        <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}"
                                         DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{DynamicResource FM_ImportFileToCategory}"
                                          Command="{Binding ImportFileToCategoryCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{DynamicResource FM_ImportFolderToCategory}"
                                          Command="{Binding ImportFolderToCategoryCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource FM_ImportDataForCategory}"
                                          Command="{Binding ImportDataForCategoryCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </HierarchicalDataTemplate>

                <HierarchicalDataTemplate DataType="{x:Type vm:FamilyLeafNodeViewModel}"
                                             ItemsSource="{Binding Children}">
                    <Grid Background="Transparent" HorizontalAlignment="Stretch"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding VersionLabel, StringFormat=' {}({0})'}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                        <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}"
                                         Focusable="False"
                                         DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                 <MenuItem Header="{DynamicResource FM_LoadAndPlace}"
                                          Command="{Binding LoadAndPlaceCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{DynamicResource FM_LoadToProject}"
                                          Command="{Binding LoadToProjectCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{DynamicResource FM_ImportData}"
                                          Command="{Binding ImportDataCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{DynamicResource FM_Update}"
                                          Command="{Binding UpdateFamilyCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{DynamicResource FM_Properties}"
                                          Command="{Binding OpenPropertiesCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                                <MenuItem Header="{DynamicResource FM_DeleteFromCatalog}"
                                          Command="{Binding DeleteFamilyCommand}"
                                          Style="{StaticResource DangerMenuItem}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </HierarchicalDataTemplate>

                <DataTemplate DataType="{x:Type vm:FamilyTypeNodeViewModel}">
                    <Grid Background="Transparent" HorizontalAlignment="Stretch"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <TextBlock Text="{Binding DisplayName}"
                                   VerticalAlignment="Center" />
                        <Grid.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}"
                                         Focusable="False"
                                         DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{DynamicResource FM_PlaceType}"
                                          Command="{Binding PlaceTypeCommand}"
                                          Style="{StaticResource ModernMenuItem}" />
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource ModernTreeViewItem}">
                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"></Setter>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"></Setter>
                    <Setter Property="AllowDrop" Value="False"></Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCategory}" Value="True">
                            <Setter Property="AllowDrop" Value="True"></Setter>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSelected}" Value="False"></Condition>
                                <Condition Binding="{Binding IsType}" Value="True"></Condition>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"></Setter>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding TotalItemCount}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>

            <Button Grid.Column="2"
                    Command="{Binding OpenCategoryEditorCommand}"
                    Width="24" Height="24" Margin="4,0,0,0"
                    Style="{DynamicResource SecondaryButton}"
                    Padding="0"
                    ToolTip="{DynamicResource FM_Tip_EditCategories}">
                <Viewbox Width="12" Height="12" Stretch="Uniform">
                    <Path Data="M 6,0.5 L 7,0.5 L 7.3,2.1 L 8.8,2.7 L 10.1,1.6 L 10.8,2.3 L 9.7,3.6 L 10.3,5.1 L 11.9,5.4 L 11.9,6.6 L 10.3,6.9 L 9.7,8.4 L 10.8,9.7 L 10.1,10.4 L 8.8,9.3 L 7.3,9.9 L 7,11.5 L 6,11.5 L 5.7,9.9 L 4.2,9.3 L 2.9,10.4 L 2.2,9.7 L 3.3,8.4 L 2.7,6.9 L 1.1,6.6 L 1.1,5.4 L 2.7,5.1 L 3.3,3.6 L 2.2,2.3 L 2.9,1.6 L 4.2,2.7 L 5.7,2.1 Z M 6.5,4 A 2.5,2.5 0 1,0 6.5,9 A 2.5,2.5 0 1,0 6.5,4"
                          Stroke="{DynamicResource TextSecondaryBrush}"
                          StrokeThickness="0.7"
                          Fill="Transparent"/>
                </Viewbox>
            </Button>
        </Grid>
    </Grid>
</UserControl>
