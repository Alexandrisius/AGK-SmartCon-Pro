<controls:DialogWindowBase x:Class="SmartCon.ProjectManagement.Views.AllowedValuesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="{DynamicResource PM_Title_AllowedValues}"
        Width="420" Height="480" MinWidth="380" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ui:SingletonResources>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="{DynamicResource PM_ValidationMode}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,6,0"/>
            <ComboBox ItemsSource="{Binding ValidationModeOptions}" SelectedItem="{Binding SelectedValidationModeOption}"
                      DisplayMemberPath="Display" Width="180"
                      Style="{DynamicResource CompactComboBox}"
                      ToolTip="{Binding SelectedValidationModeOption.Description}"/>
            <TextBlock Text="ⓘ" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="4,0,0,0"
                       ToolTip="{Binding SelectedValidationModeOption.Description}"
                       Cursor="Help"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6"
                     Visibility="{Binding ShowValuesList, Converter={StaticResource BoolToVis}}">
            <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}" Width="200"
                     Style="{DynamicResource CompactTextBox}" Margin="0,0,4,0"/>
            <Button Content="{DynamicResource PM_AddValue}" Command="{Binding AddValueCommand}"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,4,0"/>
            <Button Content="{DynamicResource PM_RemoveValue}" Command="{Binding RemoveValueCommand}"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>

        <ListBox Grid.Row="2" ItemsSource="{Binding Values}" SelectedIndex="{Binding SelectedIndex}"
                 Style="{DynamicResource CompactListBox}" Margin="0,0,0,4"
                 Visibility="{Binding ShowValuesList, Converter={StaticResource BoolToVis}}"/>

        <Grid Grid.Row="3" Margin="0,0,0,8"
              Visibility="{Binding ShowLengthFields, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource PM_MinLength}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,4,0"/>
            <TextBox Grid.Column="1" Text="{Binding MinLength}" Width="60" Style="{DynamicResource CompactTextBox}"
                     HorizontalContentAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="2" Text="{DynamicResource PM_MaxLength}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,4,0"/>
            <TextBox Grid.Column="3" Text="{Binding MaxLength}" Width="60" Style="{DynamicResource CompactTextBox}"
                     HorizontalContentAlignment="Center"/>
        </Grid>

        <Border Grid.Row="4" Background="{DynamicResource BorderAltBrush}" Height="1" Margin="0,4"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource Btn_Save}" Command="{Binding SaveCommand}"
                    Style="{DynamicResource PrimaryButton}" Margin="0,0,4,0"/>
            <Button Content="{DynamicResource Btn_Cancel}" Command="{Binding CancelCommand}"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</controls:DialogWindowBase>
