<controls:DialogWindowBase x:Class="SmartCon.ProjectManagement.Views.ExportNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SmartCon.UI;assembly=SmartCon.UI"
        xmlns:controls="clr-namespace:SmartCon.UI.Controls;assembly=SmartCon.UI"
        Title="Share Project"
        Width="520" SizeToContent="Height" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ui:SingletonResources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ui:SingletonResources>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap">
            <Run Text="{DynamicResource PM_ExportName_CurrentLabel}" FontWeight="Bold"/>
            <Run Text="{Binding CurrentFileName, Mode=OneWay}"/>
        </TextBlock>

        <TextBlock Grid.Row="1" Margin="0,0,0,12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Text="{Binding ValidationErrors, Mode=OneWay}"/>

        <TextBlock Grid.Row="2" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontWeight="Bold"
                   Text="{DynamicResource PM_ExportName_FillFields}"/>

        <ItemsControl Grid.Row="3" ItemsSource="{Binding Fields}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding Field}"/>
                        <ComboBox Grid.Column="1"
                                  IsEditable="True"
                                  Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AllowedValues}"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBox Grid.Row="4" Margin="0,4,0,8"
                 Foreground="Red"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 BorderThickness="0"
                 Background="Transparent"
                 MaxHeight="80"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding FieldErrors, Mode=OneWay}">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FieldErrors}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding FieldErrors}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold">
                <Run Text="{DynamicResource PM_ExportName_Preview}"/>
                <Run Text="{Binding PreviewFileName, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Export}"
                    Command="{Binding ExportCommand}"
                    IsEnabled="{Binding IsValid}"
                    Margin="0,0,8,0"
                    MinWidth="80" MinHeight="28"/>
            <Button Content="{DynamicResource Btn_Cancel}"
                    Command="{Binding CancelCommand}"
                    MinWidth="80" MinHeight="28"/>
        </StackPanel>
    </Grid>
</controls:DialogWindowBase>
